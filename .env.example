# ── CodeAtlas — local development environment ─────────────────────────────
# Copy this file to .env and fill in the values.
# .env is listed in .gitignore and never committed.

# PostgreSQL connection string.
# Leave blank to use a local SQLite file (codeatlas_local.db) instead.
# On Replit this is injected automatically — you don't need to set it there.
DATABASE_URL=

# Secret used to sign JWT session tokens.
# Any long random string works for local dev.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET=change-me-to-a-random-secret

# OpenAI API key — required for AI summary, chat, and feature-assistant.
# Leave blank to use CodeAtlas without AI features.
OPENAI_API_KEY=
