{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Backend: start uvicorn (port 8000)",
      "type": "shell",
      "command": "uvicorn app.main:app --host 0.0.0.0 --port 8000 || python -m uvicorn app.main:app --host 0.0.0.0 --port 8000",
      "options": {
        "cwd": "${workspaceFolder}/backend"
      },
      "presentation": {
        "group": "codeatlas",
        "panel": "dedicated",
        "reveal": "always"
      },
      "isBackground": true,
      "problemMatcher": {
        "pattern": { "regexp": "^$" },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".*Waiting for application startup.*",
          "endsPattern": ".*Application startup complete.*"
        }
      }
    },
    {
      "label": "Frontend: start Vite (port 5000)",
      "type": "shell",
      "command": "npm run dev",
      "options": {
        "cwd": "${workspaceFolder}/frontend"
      },
      "presentation": {
        "group": "codeatlas",
        "panel": "dedicated",
        "reveal": "always"
      },
      "isBackground": true,
      "problemMatcher": {
        "pattern": { "regexp": "^$" },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".*VITE.*ready.*",
          "endsPattern": ".*Local:.*localhost.*"
        }
      }
    },
    {
      "label": "CodeAtlas: start both (backend + frontend)",
      "dependsOrder": "parallel",
      "dependsOn": [
        "Backend: start uvicorn (port 8000)",
        "Frontend: start Vite (port 5000)"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always"
      }
    }
  ]
}
